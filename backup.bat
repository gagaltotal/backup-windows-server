echo =  BACKUP WINDOWS SERVER - NAS                                                                                     =
echo ====================================================================================================================

:: ================================
:: CONFIG NAS LOGIN
:: ================================
set NAS=\\192.168.1.666\backup\backup-windows-server
set USERNAS=your_username
set PASSNAS=your_password

:: ================================
:: SOURCE & DESTINATION
:: ================================
set SOURCE=C:\Users
set DEST=%NAS%\server2012_users
set LOG=C:\backup_log.txt

:: ================================
:: CONNECT TO NAS
:: ================================
net use %NAS% /user:%USERNAS% %PASSNAS% /persistent:no

:: ================================
:: CREATE DEST FOLDER IF NOT EXIST
:: ================================
if not exist "%DEST%" (
mkdir "%DEST%"
)

:: ================================
:: BACKUP START
:: ================================
echo Backup started at %date% %time% >> %LOG%

robocopy "%SOURCE%" "%DEST%" ^
/E ^
/Z ^
/XO ^
/R:2 ^
/W:5 ^
/FFT ^
/XA:SH ^
/XD "C:\Users\All Users" "C:\Users\Default" "C:\Users\Default User" "C:\Users\Public" ^
/LOG+:%LOG%

echo Backup finished at %date% %time% >> %LOG%
echo ================================ >> %LOG%

:: ================================
:: DISCONNECT NAS
:: ================================
net use %NAS% /delete
